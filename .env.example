# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Supabase / Postgres ---
# Pooled connection (Supavisor) — used by the running app on Vercel (serverless).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection — used ONLY for Prisma migrations (not by serverless functions).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Seed data sources (used by prisma/seed.ts, run offline) ---
# CollegeFootballData.com API key (free, requires signup).
CFBD_API_KEY=""
